{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/Quiz.html",
      "destination": "/prozess-check",
      "permanent": true
    },
    {
      "source": "/Quiz",
      "destination": "/prozess-check",
      "permanent": true
    },
    {
      "source": "/quiz.html",
      "destination": "/prozess-check",
      "permanent": true
    },
    {
      "source": "/quiz",
      "destination": "/prozess-check",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/prozess-check",
      "destination": "/prozess-check/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/dist/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
